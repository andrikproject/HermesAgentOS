        android:pathData="M54,30 A24,24 0 1,0 53.9,30" />

    <!-- LEFT WING OF HERMES (Agent Speed & Transmission) -->
    <path
        android:pathData="M38,42 C26,42 22,54 34,60 C40,63 46,55 46,50 Z"
        android:strokeWidth="1"
        android:strokeColor="#14B8A6">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="22"
                android:startY="42"
                android:endX="46"
                android:endY="60"
                android:type="linear">
                <item android:offset="0.0" android:color="#14B8A6" />
                <item android:offset="1.0" android:color="#0F766E" />
